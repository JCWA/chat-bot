{
  "name": "chat-bot",
  "version": "0.1.0",
  "description": "AI chatbot server based on NestJS + Socket.io",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node -r tsconfig-paths/register dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src}/**/*.ts\" --fix"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.15",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.4.7",
    "@nestjs/websockets": "^10.4.7",
    "@supabase/supabase-js": "^2.102.1",
    "dotenv": "^17.4.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/node": "^20.3.1",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
